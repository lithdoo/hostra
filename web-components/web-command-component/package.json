  },
  "dependencies": {
    "xterm": "^5.3.0",
    "xterm-addon-attach": "^0.9.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "happy-dom": "^16.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.7.2",
    "vite": "^6.0.3"
  }
}
