{
  "name": "@web-editor/web-command-component",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/web-command-component.js",
  "module": "./dist/web-command-component.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/web-command-component.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && tsc --emitDeclarationOnly",
